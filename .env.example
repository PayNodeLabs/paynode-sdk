# --- PayNode Python SDK Configuration ---

# [REQUIRED] Your AI Agent's Private Key (for signing payments)
# Base Sepolia Testnet PK for testing, or Mainnet PK for production.
CLIENT_PRIVATE_KEY=0xYourPrivateKeyHere

# [OPTIONAL] Your Merchant Wallet Address (where you want to receive payments)
# Only required if you are running the Merchant FastAPI Server demo.
MERCHANT_ADDRESS=0xYourMerchantWalletAddress

# [OPTIONAL] The URL of the protected resource
# Used by the agent_client.py demo.
TARGET_MERCHANT_URL=http://localhost:8000/api/premium-python-data

# Note: All protocol-level constants (Router Address, USDC Address, RPC URLs)
# are automatically managed by the SDK's constants module (SSoT).
